                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Client API"
                ],
                "summary": "Generate Content (Gemini)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Model and Action (e.g. gemini-pro:generateContent)",
